# Example environment variables for backend
# Copy this to ".env" and adjust values as needed

# Database connection string
DATABASE_URL='postgresql://neondb_owner:REMOVED@REMOVED/neondb?sslmode=require&channel_binding=require'

# JWT secret for authentication
JWT_SECRET="your-jwt-secret-key"

# Frontend Origin - set this to your deployed frontend URL in production
FRONTEND_ORIGIN="http://localhost:5173"

# Server port (optional, defaults to 4000)
PORT=4000

# Email Configuration (for OTP functionality)
EMAIL_USER="REMOVED"
EMAIL_PASS="REMOVED"
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"


# Special Admin Route Credentials (for /admin-login route)
SPECIAL_ADMIN_USERNAME="specialadmin"
SPECIAL_ADMIN_PASSWORD="REMOVED"
SPECIAL_ADMIN_SECRET="REMOVED"
SPECIAL_ADMIN_EMAIL="your-admin-email@gmail.com"
