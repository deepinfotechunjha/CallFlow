generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     Int                      @id @default(autoincrement())
  username               String                   @unique
  password               String
  email                  String                   @unique
  phone                  String                   @unique
  createdAt              DateTime                 @default(now())
  role                   String
  secretPassword         String                   @default("DEFAULTSECRET")
  deletionHistory        DeletionHistory[]
  salesEntries           SalesEntry[]
  salesLogs              SalesLog[]
  serviceDeletionHistory ServiceDeletionHistory[]
  orders                 Order[]
  orderHolds             OrderHold[]
}

model Call {
  id             Int       @id @default(autoincrement())
  problem        String
  category       String
  status         String
  assignedTo     String?
  assignedAt     DateTime?
  createdBy      String
  createdAt      DateTime  @default(now())
  completedBy    String?
  completedAt    DateTime?
  customerId     Int?
  address        String?
  customerName   String
  email          String?
  phone          String
  remark         String?
  engineerRemark String?
  assignedBy     String?
  callCount      Int       @default(1)
  lastCalledAt   DateTime  @default(now())
  visitedAt      DateTime?
  visitedBy      String?
  visitedRemark  String?
  dcCompletedAt  DateTime?
  dcCompletedBy  String?
  dcRemark       String?
  dcRequired     Boolean   @default(false)
  dcStatus       String?
  customer       Customer? @relation(fields: [customerId], references: [id])

  @@index([assignedTo])
  @@index([createdBy])
  @@index([phone, category, status])
  @@index([dcRequired, dcStatus])
}

model Customer {
  id                Int              @id @default(autoincrement())
  name              String
  phone             String           @unique
  email             String?
  address           String?
  createdAt         DateTime         @default(now())
  outsideCalls      Int              @default(0)
  carryInServices   Int              @default(0)
  totalInteractions Int              @default(0)
  lastCallDate      DateTime?
  lastServiceDate   DateTime?
  lastActivityDate  DateTime?
  calls             Call[]
  services          CarryInService[]
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  callId    Int?

  @@index([userId, isRead])
}

model City {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  areas     Area[]

  @@index([name])
}

model Area {
  id        Int      @id @default(autoincrement())
  name      String
  cityId    Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  city      City     @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([name, cityId])
  @@index([cityId])
  @@index([name])
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CarryInService {
  id                 Int       @id @default(autoincrement())
  customerName       String
  phone              String
  email              String?
  address            String?
  category           String
  serviceDescription String?
  status             String    @default("PENDING")
  customerId         Int?
  createdBy          String
  createdAt          DateTime  @default(now())
  completedBy        String?
  completedAt        DateTime?
  completeRemark     String?
  deliveredBy        String?
  deliveredAt        DateTime?
  deliverRemark      String?
  customer           Customer? @relation(fields: [customerId], references: [id])

  @@index([phone])
  @@index([status])
  @@index([createdBy])
}

model OtpToken {
  id        Int      @id @default(autoincrement())
  email     String
  otp       String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, token])
  @@index([expiresAt])
}

model DeletionHistory {
  id            Int      @id @default(autoincrement())
  deletedBy     Int
  deletedByName String
  deletedAt     DateTime @default(now())
  callCount     Int
  user          User     @relation(fields: [deletedBy], references: [id], onDelete: Cascade)

  @@index([deletedBy])
  @@index([deletedAt])
}

model ServiceDeletionHistory {
  id            Int      @id @default(autoincrement())
  deletedBy     Int
  deletedByName String
  deletedAt     DateTime @default(now())
  serviceCount  Int
  user          User     @relation(fields: [deletedBy], references: [id], onDelete: Cascade)

  @@index([deletedBy])
  @@index([deletedAt])
}

model SalesEntry {
  id                   Int        @id @default(autoincrement())
  firmName             String     @db.VarChar(255)
  gstNo                String     @unique @db.VarChar(15)
  contactPerson1Name   String     @db.VarChar(100)
  contactPerson1Number String     @db.VarChar(15)
  contactPerson2Name   String?    @db.VarChar(100)
  contactPerson2Number String?    @db.VarChar(15)
  accountContactName   String?    @db.VarChar(100)
  accountContactNumber String?    @db.VarChar(15)
  address              String     @db.VarChar(500)
  landmark             String?    @db.VarChar(200)
  pincode              String     @db.VarChar(6)
  email                String?    @db.VarChar(255)
  createdBy            String     @db.VarChar(50)
  createdById          Int?
  createdAt            DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime   @updatedAt @db.Timestamptz(6)
  delayCount           Int        @default(0)
  delayedBy            String[]   @default([])
  lastActivityDate     DateTime?  @db.Timestamptz(6)
  reminderDate         DateTime?  @db.Timestamptz(6)
  area                 String?    @db.VarChar(100)
  city                 String     @db.VarChar(100)
  whatsappNumber       String?    @db.VarChar(15)
  creator              User?      @relation(fields: [createdById], references: [id])
  logs                 SalesLog[]
  orders               Order[]

  @@index([firmName])
  @@index([city])
  @@index([gstNo])
  @@index([createdBy])
  @@index([createdAt])
  @@index([contactPerson1Number])
  @@index([reminderDate])
}

model SalesLog {
  id               Int        @id @default(autoincrement())
  salesEntryId     Int
  logType          String     @db.VarChar(10)
  callType         String?    @db.VarChar(10)
  remark           String?
  loggedBy         String     @db.VarChar(50)
  loggedById       Int?
  loggedAt         DateTime   @default(now()) @db.Timestamptz(6)
  latitude         Float?
  locationAccuracy Float?
  longitude        Float?
  logger           User?      @relation(fields: [loggedById], references: [id])
  salesEntry       SalesEntry @relation(fields: [salesEntryId], references: [id], onDelete: Cascade)

  @@index([salesEntryId, loggedAt(sort: Desc)])
  @@index([logType])
  @@index([loggedBy])
  @@index([loggedAt(sort: Desc)])
}

model PublicAccessToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([expiresAt])
}

model Order {
  id               Int         @id @default(autoincrement())
  salesEntryId     Int
  orderRemark      String
  calledBy         String?     @db.VarChar(50)
  status           String      @default("PENDING")
  createdBy        String      @db.VarChar(50)
  createdById      Int?
  createdAt        DateTime    @default(now()) @db.Timestamptz(6)
  billingRemark    String?
  billedBy         String?     @db.VarChar(50)
  billedAt         DateTime?   @db.Timestamptz(6)
  completionRemark String?
  completedBy      String?     @db.VarChar(50)
  completedAt      DateTime?   @db.Timestamptz(6)
  cancelledBy      String?     @db.VarChar(50)
  cancelledAt      DateTime?   @db.Timestamptz(6)
  revertRemark     String?
  creator          User?       @relation(fields: [createdById], references: [id])
  salesEntry       SalesEntry  @relation(fields: [salesEntryId], references: [id])
  holds            OrderHold[]

  @@index([salesEntryId])
  @@index([status])
  @@index([createdById])
  @@index([createdAt])
}

model OrderHold {
  id         Int      @id @default(autoincrement())
  orderId    Int
  remark     String
  heldBy     String   @db.VarChar(50)
  heldById   Int?
  heldAt     DateTime @default(now()) @db.Timestamptz(6)
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  holder     User?    @relation(fields: [heldById], references: [id])

  @@index([orderId])
  @@index([heldAt])
}
